{
  "manifest_version": 3,
  "name": "Focus Timer",
  "version": "1.0",
  "description": "A simple Pomodoro focus timer.",
  "permissions": [
    "alarms",
    "storage",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Timer"
  },
  "background": {
    "service_worker": "background.js"
  }
}